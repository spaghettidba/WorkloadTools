<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v4 SDK-style project. No Visual Studio WiX extension is required to build.
  Restore NuGet packages first (msbuild -t:Restore or dotnet restore), then build normally.
  Use buildmsi.ps1 for a standalone build that also handles code signing.
-->
<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName>WorkloadTools</OutputName>
    <OutputType>Package</OutputType>
    <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
    <!-- Default version for local developer builds; CI always passes DefineConstants explicitly -->
    <DefineConstants Condition="'$(DefineConstants)' == ''">BuildVersion=0.0.0.0</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="WixToolset.Heat.wixext" Version="4.0.5" />
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.5" />
  </ItemGroup>
  <!--
    HarvestDirectory items replace the WiX v3 HeatDirectory MSBuild tasks.
    The WiX Heat extension harvests the output directories of the .NET projects
    and generates component groups that are referenced from Product.wxs.
    XSL transforms filter out duplicate and unwanted files.
  -->
  <ItemGroup>
    <HarvestDirectory Include="..\SqlWorkload\bin\$(Platform)\$(Configuration)">
      <ComponentGroupName>ProductComponents</ComponentGroupName>
      <DirectoryRefId>INSTALLFOLDER</DirectoryRefId>
      <SuppressRootDirectory>true</SuppressRootDirectory>
      <SuppressRegistry>true</SuppressRegistry>
      <Transforms>$(MSBuildThisFileDirectory)transform.xsl</Transforms>
    </HarvestDirectory>
    <HarvestDirectory Include="..\WorkloadViewer\bin\$(Platform)\$(Configuration)">
      <ComponentGroupName>WorkloadViewerComponents</ComponentGroupName>
      <DirectoryRefId>INSTALLFOLDER</DirectoryRefId>
      <SuppressRootDirectory>true</SuppressRootDirectory>
      <SuppressRegistry>true</SuppressRegistry>
      <Transforms>$(MSBuildThisFileDirectory)transform.xsl;$(MSBuildThisFileDirectory)transform2.xsl</Transforms>
    </HarvestDirectory>
  </ItemGroup>
  <ItemGroup>
    <Content Include="postbuild.bat" />
    <Content Include="SignMsi.ps1" />
    <Content Include="transform.xsl" />
    <Content Include="transform2.xsl" />
  </ItemGroup>
  <PropertyGroup>
    <!-- Use a fixed product name so the signed output is WorkloadTools_<Platform>.msi
         even when the project is built outside of the solution context. -->
    <PostBuildEvent>call $(ProjectDir)postbuild.bat "$(TargetPath)" "$(TargetDir)WorkloadTools_$(Platform)$(TargetExt)"</PostBuildEvent>
  </PropertyGroup>
</Project>